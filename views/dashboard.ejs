<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Frecuencias</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --accent: #818cf8;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg: #0f172a;
            --glass: rgba(30, 41, 59, 0.7);
            --text: #f8fafc;
            --text-muted: #94a3b8;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            justify-content: center;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(5px);
        }
        .modal-content {
            width: 95%;
            max-width: 550px;
            padding: 1.25rem 1.75rem;
            max-height: 95vh;
            overflow-y: auto;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .grid-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }
        .form-group {
            margin-bottom: 0.5rem;
        }
        .form-group label {
            margin-bottom: 0.25rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .form-group input, .form-group select {
            padding: 0.5rem 0.75rem;
            font-size: 0.9rem;
        }
        .full-width { grid-column: span 2; }
        
        /* Tabs */
        .tabs {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 0.5rem;
        }
        .tab-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            border-radius: 0.5rem;
        }
        .tab-btn:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .tab-btn.active {
            color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
        }
        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s ease; }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .alert {
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 1.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .alert-info { background: rgba(99, 102, 241, 0.2); border: 1px solid var(--primary); color: #c7d2fe; }
        .alert-success { background: rgba(34, 197, 94, 0.2); border: 1px solid var(--success); color: #bbf7d0; }

        .fav-btn {
            background: none;
            border: none;
            font-size: 1.25rem;
            cursor: pointer;
            transition: transform 0.2s;
            padding: 0;
            margin-right: 0.5rem;
        }
        .fav-btn:hover { transform: scale(1.2); }
        .fav-btn.active { color: #facc15; }
        .fav-btn.inactive { color: var(--text-muted); opacity: 0.5; }

        .diff-tag {
            font-size: 0.7rem;
            padding: 0.1rem 0.4rem;
            border-radius: 0.25rem;
            background: rgba(255,255,255,0.1);
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <header class="header glass" style="border-radius: 0; border-top: none; border-left: none; border-right: none;">
        <div style="font-weight: 700; font-size: 1.5rem; color: var(--accent);">Frecuency</div>
        <div style="display: flex; align-items: center; gap: 1.5rem;">
            <div style="text-align: right;">
                <div style="font-weight: 600;"><%= user.nombre %></div>
                <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user.rol.toUpperCase() %></div>
            </div>
            <a href="/logout" class="btn" style="width: auto; padding: 0.5rem 1rem; background: rgba(255, 255, 255, 0.1);">Salir</a>
        </div>
    </header>

    <main class="container">
        <% if (notificaciones && notificaciones.length > 0) { %>
            <div id="notification-area" class="glass" style="padding: 1.25rem; margin-bottom: 2rem; border-left: 4px solid var(--primary); animation: fadeIn 0.5s ease;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h4 style="font-size: 0.75rem; color: var(--primary); letter-spacing: 0.1em; text-transform: uppercase;">Notificaciones</h4>
                    <button onclick="clearNotifications()" style="background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:0.75rem; text-decoration: underline;">Limpiar</button>
                </div>
                <% notificaciones.forEach(n => { %>
                    <div style="font-size: 0.9rem; padding: 0.75rem 0; border-top: 1px solid rgba(255,255,255,0.05);">
                        <span style="color: var(--text-muted); font-size: 0.7rem; margin-right: 0.75rem;"><%= new Date(n.fecha).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                        <%= n.mensaje %>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <% if (typeof msg !== 'undefined' || (typeof req !== 'undefined' && req.query.msg)) { %>
            <% const m = (typeof msg !== 'undefined') ? msg : req.query.msg; %>
            <% if (m === 'pendiente') { %>
                <div class="alert alert-info">✓ Solicitud enviada correctamente. Un administrador la revisará pronto.</div>
            <% } else if (m === 'aprobado') { %>
                <div class="alert alert-success">✓ Solicitud aprobada y aplicada.</div>
            <% } %>
        <% } %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h2>Frecuencias</h2>
            <div style="display: flex; gap: 1rem;">
                <% if (user.rol === 'admin') { %>
                    <button class="btn btn-secondary" onclick="openModal('importModal')">📥 Importar CSV</button>
                <% } %>
                <button class="btn btn-success" onclick="openModal('addModal')">+ Sugerir Frecuencia</button>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" id="tab-btn-general" onclick="showTab('general')">General</button>
            <button class="tab-btn" id="tab-btn-favoritos" onclick="showTab('favoritos')">Mis Favoritos</button>
            <% if (user.rol === 'admin') { %>
                <button class="tab-btn" id="tab-btn-revisiones" onclick="showTab('revisiones')">Revisiones (<%= solicitudes.length %>)</button>
                <button class="tab-btn" id="tab-btn-usuarios" onclick="showTab('usuarios')">Usuarios</button>
            <% } %>
        </div>

        <div id="tab-general" class="tab-content active">
            <div class="table-container glass">
                <table>
                    <thead>
                        <tr>
                            <th></th>
                            <th onclick="sortTable('generalTable', 1)" style="cursor:pointer">TX ↕</th>
                            <th onclick="sortTable('generalTable', 2)" style="cursor:pointer">RX ↕</th>
                            <th onclick="sortTable('generalTable', 3)" style="cursor:pointer">Mod ↕</th>
                            <th onclick="sortTable('generalTable', 4)" style="cursor:pointer">SubT ↕</th>
                            <th onclick="sortTable('generalTable', 5)" style="cursor:pointer">Señal ↕</th>
                            <th onclick="sortTable('generalTable', 6)" style="cursor:pointer">Banda ↕</th>
                            <th onclick="sortTable('generalTable', 7)" style="cursor:pointer">Estado ↕</th>
                            <th onclick="sortTable('generalTable', 8)" style="cursor:pointer">Titular ↕</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="generalTable">
                        <% data.forEach(row => { %>
                            <tr>
                                <td>
                                    <button class="fav-btn <%= row.es_favorito ? 'active' : 'inactive' %>" onclick="toggleFavorite(<%= row.id %>)">
                                        <%= row.es_favorito ? '★' : '☆' %>
                                    </button>
                                </td>
                                <td><%= row.tx %></td>
                                <td><%= row.rx %></td>
                                <td><%= row.mod %></td>
                                <td><%= row.subt %></td>
                                <td><strong><%= row.signal %></strong></td>
                                <td><%= row.banda %></td>
                                <td><span class="badge badge-<%= row.estado_color %>"><%= row.estado_nombre %></span></td>
                                <td><%= row.titular %></td>
                                <td class="actions-cell">
                                    <button class="btn btn-secondary" onclick='editRow(<%= JSON.stringify(row) %>)'>✎</button>
                                    <form action="/api/datos/delete/<%= row.id %>" method="POST" onsubmit="return confirm('¿Eliminar registro?')">
                                        <button class="btn btn-danger">🗑</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="tab-favoritos" class="tab-content">
            <div class="table-container glass">
                <table>
                    <thead>
                        <tr>
                            <th onclick="sortTable('favTable', 0)" style="cursor:pointer"># Personal ↕</th>
                            <th onclick="sortTable('favTable', 1)" style="cursor:pointer">Señal ↕</th>
                            <th onclick="sortTable('favTable', 2)" style="cursor:pointer">TX ↕</th>
                            <th onclick="sortTable('favTable', 3)" style="cursor:pointer">RX ↕</th>
                            <th onclick="sortTable('favTable', 4)" style="cursor:pointer">SubT ↕</th>
                            <th onclick="sortTable('favTable', 5)" style="cursor:pointer">Titular ↕</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="favTable">
                        <% const favorites = data.filter(d => d.es_favorito); %>
                        <% if (favorites.length === 0) { %>
                            <tr><td colspan="7" style="text-align: center; padding: 2rem;">No tienes favoritos guardados.</td></tr>
                        <% } else { %>
                            <% favorites.forEach(row => { %>
                                <tr>
                                    <td>
                                        <span style="font-weight: 700; color: var(--accent); margin-right: 0.5rem;"><%= row.memoria_personalizada || row.mem || '-' %></span>
                                        <button class="btn btn-sm btn-info" onclick="openMemModal(<%= row.id %>, '<%= row.memoria_personalizada || '' %>')">edit</button>
                                    </td>
                                    <td><strong><%= row.signal %></strong></td>
                                    <td><%= row.tx %></td>
                                    <td><%= row.rx %></td>
                                    <td><%= row.subt %></td>
                                    <td><%= row.titular %></td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="toggleFavorite(<%= row.id %>)">Quitar</button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <% if (user.rol === 'admin') { %>
            <div id="tab-revisiones" class="tab-content">
                <div class="table-container glass">
                    <table>
                        <thead>
                            <tr>
                                <th onclick="sortTable('revTable', 0)" style="cursor:pointer">Fecha ↕</th>
                                <th onclick="sortTable('revTable', 1)" style="cursor:pointer">Usuario ↕</th>
                                <th onclick="sortTable('revTable', 2)" style="cursor:pointer">Tipo ↕</th>
                                <th>Datos Sugeridos</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="revTable">
                            <% if (solicitudes.length === 0) { %>
                                <tr><td colspan="5" style="text-align: center; padding: 2rem;">No hay revisiones pendientes.</td></tr>
                            <% } else { %>
                                <% solicitudes.forEach(sol => { %>
                                    <% const datos = JSON.parse(sol.datos_json); %>
                                    <% 
                                        const fields = [
                                            {key: 'mem', label: 'MEM'},
                                            {key: 'tx', label: 'TX'},
                                            {key: 'rx', label: 'RX'},
                                            {key: 'mod', label: 'MOD'},
                                            {key: 'subt', label: 'SubT'},
                                            {key: 'signal', label: 'Señal'},
                                            {key: 'banda', label: 'Banda'},
                                            {key: 'titular', label: 'Titular'},
                                            {key: 'ciudad', label: 'Ciudad'}
                                        ]; 
                                    %>
                                    <tr>
                                        <td style="font-size: 0.75rem;"><%= new Date(sol.fecha_solicitud).toLocaleString() %></td>
                                        <td><%= sol.usuario_nombre %></td>
                                        <td>
                                            <span class="badge" style="background: <%= sol.tipo === 'alta' ? 'rgba(34, 197, 94, 0.2)' : (sol.tipo === 'edicion' ? 'rgba(245, 158, 11, 0.2)' : 'rgba(239, 68, 68, 0.2)') %>; color: <%= sol.tipo === 'alta' ? '#bbf7d0' : (sol.tipo === 'edicion' ? '#fde68a' : '#fecaca') %>;">
                                                <%= sol.tipo.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td style="font-size: 0.85rem;">
                                            <% if (sol.tipo === 'edicion') { %>
                                                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                                                    <% fields.forEach(f => { %>
                                                        <% if (String(datos[f.key] || '') !== String(sol['old_' + f.key] || '')) { %>
                                                            <div style="background: rgba(255,255,255,0.03); padding: 0.25rem 0.5rem; border-radius: 0.25rem;">
                                                                <span class="diff-tag"><%= f.label %></span>
                                                                <span style="color: var(--danger); text-decoration: line-through; margin-right: 0.5rem;"><%= sol['old_' + f.key] || '(vacío)' %></span>
                                                                <span style="color: var(--success); font-weight: 700;"><%= datos[f.key] || '(vacío)' %></span>
                                                            </div>
                                                        <% } %>
                                                    <% }) %>
                                                </div>
                                            <% } else { %>
                                                <div><strong><%= datos.signal %></strong> (<%= datos.tx %> / <%= datos.rx %>)</div>
                                                <div style="color: var(--text-muted); font-size: 0.75rem;">Titular: <%= datos.titular %></div>
                                            <% } %>
                                        </td>
                                        <td class="actions-cell">
                                            <form action="/api/admin/solicitudes/<%= sol.id %>/aprobar" method="POST" style="display:inline">
                                                <button type="submit" class="btn" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">Aprobar</button>
                                            </form>
                                            <form action="/api/admin/solicitudes/<%= sol.id %>/rechazar" method="POST" style="display:inline">
                                                <button type="submit" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.75rem; background: rgba(239, 68, 68, 0.2);">X</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

        <% if (user.rol === 'admin') { %>
            <div id="tab-usuarios" class="tab-content">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3>Gestión de Usuarios</h3>
                    <button class="btn" style="width: auto; padding: 0.5rem 1rem;" onclick="openModal('addUserModal')">+ Nuevo Usuario</button>
                </div>
                <div class="table-container glass">
                    <table>
                        <thead>
                            <tr>
                                <th onclick="sortTable('userTable', 0)" style="cursor:pointer">Nombre ↕</th>
                                <th onclick="sortTable('userTable', 1)" style="cursor:pointer">Usuario ↕</th>
                                <th onclick="sortTable('userTable', 2)" style="cursor:pointer">Correo ↕</th>
                                <th onclick="sortTable('userTable', 3)" style="cursor:pointer">Rol ↕</th>
                                <th onclick="sortTable('userTable', 4)" style="cursor:pointer">Fecha Alta ↕</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="userTable">
                            <% usuarios_lista.forEach(u => { %>
                                <tr>
                                    <td><%= u.nombre %></td>
                                    <td><strong><%= u.usuario %></strong></td>
                                    <td><%= u.correo %></td>
                                    <td>
                                        <span class="badge" style="background: <%= u.rol === 'admin' ? 'rgba(99, 102, 241, 0.2)' : 'rgba(148, 163, 184, 0.2)' %>; color: <%= u.rol === 'admin' ? '#c7d2fe' : '#94a3b8' %>;">
                                            <%= u.rol.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td style="font-size: 0.75rem;"><%= new Date(u.fecha_alta).toLocaleDateString() %></td>
                                    <td class="actions-cell">
                                        <button class="action-btn edit-btn" onclick='editUserRow(<%= JSON.stringify(u) %>)'>✎</button>
                                        <% if (u.id !== user.id) { %>
                                            <form action="/api/admin/usuarios/delete/<%= u.id %>" method="POST" style="display:inline" onsubmit="return confirm('¿Eliminar usuario? Esta acción no se puede deshacer.')">
                                                <button type="submit" class="action-btn delete-btn">🗑</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
        
        <footer style="margin-top: 4rem; padding: 2rem 0; border-top: 1px solid rgba(255,255,255,0.05); text-align: center; color: var(--text-muted); font-size: 0.85rem;">
            <p>© 2025 Frecuency Management System - v1.2.0</p>
            <p style="margin-top: 0.5rem;">Desarrollado con ❤️ por <strong>sector7gp</strong></p>
            <p style="margin-top: 1rem;">
                <a href="#" style="color: var(--primary); text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
                    <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 496 512" height="1.2em" width="1.2em" xmlns="http://www.w3.org/2000/svg"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.4 2.3 17.2-5.1 17.2-12.2 0-5.7-.2-20.5-.3-40.2-66.9 14.4-80.6-32.9-80.6-32.9-11-28-26.9-35.4-26.9-35.4-21.8-14.9 1.7-14.5 1.7-14.5 24.2 1.6 37 24.8 37 24.8 21.5 37 54.8 26.3 68.1 20.1 2.2-15.5 8.4-26.3 15.3-32.4-53.5-6.2-109.8-26.7-109.8-119.3 0-26.4 9.3-48 24.5-64.5-2.5-6.1-10.6-30.6 2.4-63.6 0 0 20.3-6.5 66.2 24.7 19.3-5.4 40-8.1 60.6-8.1 20.6 0 41.3 2.7 60.6 8.1 45.9-31.2 66.2-24.7 66.2-24.7 13 33 4.9 57.5 2.4 63.6 15.2 16.5 24.5 38.1 24.5 64.5 0 92.7-56.3 113-110.1 119.1 8.7 7.4 16.3 22.3 16.3 45 0 32.5-.3 58.7-.3 66.7 0 7.2 4.8 15.6 17.3 12.1C426.2 457.8 496 362.9 496 252 496 113.3 389.9 8 244.8 8zM108.5 383.9c-.8 1.6.5 3.5 2.5 4.1 1.9.8 4.4-.3 5.1-1.9 1-1.6-.3-3.5-2.4-4.1-2-.7-4.4.2-5.1 1.9zm-8.8-5.7c-1.4 1.1-.3 3.1 2 4.1 2.7 1.2 5.4 1.2 6.5-.1 1.1-1.1.2-3.1-2.1-4.1-2.8-1.2-5.5-1.1-6.4.1zm-8.3-9.5c-1.6 1.1-1.5 3.3.3 4.8 1.8 1.6 4.6 1.8 6.1.6 1.7-1.1 1.4-3.4-.4-4.8-1.8-1.7-4.6-1.9-6-1zm-11.7-11.7c-2 1.1-2.5 3.3-1.1 5 1.4 1.7 4.1 1.8 6.1.8 2-1 2.5-3.2 1.1-5-1.4-1.7-4.1-1.8-6.1-.8z"></path></svg>
                    GitHub Repository
                </a>
            </p>
        </footer>
    </main>

    <!-- Add Modal -->
    <div id="addModal" class="modal">
        <div class="modal-content glass">
            <h3>Agregar Frecuencia</h3>
            <form action="/api/datos" method="POST" class="grid-form">
                <div class="form-group"><label>TX</label><input type="text" name="tx"></div>
                <div class="form-group"><label>RX</label><input type="text" name="rx"></div>
                <div class="form-group"><label>MOD</label><input type="text" name="mod"></div>
                <div class="form-group"><label>SubT (Hz)</label><input type="text" name="subt"></div>
                <div class="form-group"><label>SEÑAL</label><input type="text" name="signal" required></div>
                <div class="form-group"><label>Banda</label><input type="text" name="banda"></div>
                <div class="form-group">
                    <label>Estado</label>
                    <select name="id_estado">
                        <% estados.forEach(e => { %>
                            <option value="<%= e.id %>"><%= e.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group full-width"><label>TITULAR</label><input type="text" name="titular"></div>
                <div class="form-group"><label>CIUDAD</label><input type="text" name="ciudad"></div>
                <div class="form-group">
                    <label>PROVINCIA</label>
                    <select name="id_provincia">
                        <% provincias.forEach(p => { %>
                            <option value="<%= p.id %>"><%= p.nombre %> (<%= p.codigo_aereo %>)</option>
                        <% }) %>
                    </select>
                </div>
                <div class="full-width" style="display: flex; gap: 1rem; margin-top: 1rem;">
                    <button type="submit" class="btn">Guardar</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal('addModal')">Cerrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal">
        <div class="modal-content glass">
            <h3>Editar Frecuencia</h3>
            <form id="editForm" method="POST" class="grid-form">
                <div class="form-group"><label>TX</label><input type="text" name="tx" id="edit_tx"></div>
                <div class="form-group"><label>RX</label><input type="text" name="rx" id="edit_rx"></div>
                <div class="form-group"><label>MOD</label><input type="text" name="mod" id="edit_mod"></div>
                <div class="form-group"><label>SubT (Hz)</label><input type="text" name="subt" id="edit_subt"></div>
                <div class="form-group"><label>SEÑAL</label><input type="text" name="signal" id="edit_signal" required></div>
                <div class="form-group"><label>Banda</label><input type="text" name="banda" id="edit_banda"></div>
                <div class="form-group">
                    <label>Estado</label>
                    <select name="id_estado" id="edit_id_estado">
                        <% estados.forEach(e => { %>
                            <option value="<%= e.id %>"><%= e.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group full-width"><label>TITULAR</label><input type="text" name="titular" id="edit_titular"></div>
                <div class="form-group"><label>CIUDAD</label><input type="text" name="ciudad" id="edit_ciudad"></div>
                <div class="form-group">
                    <label>PROVINCIA</label>
                    <select name="id_provincia" id="edit_id_provincia">
                        <% provincias.forEach(p => { %>
                            <option value="<%= p.id %>"><%= p.nombre %> (<%= p.codigo_aereo %>)</option>
                        <% }) %>
                    </select>
                </div>
                <div class="full-width" style="display: flex; gap: 1rem; margin-top: 1rem;">
                    <button type="submit" class="btn btn-primary">Actualizar</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cerrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Personal Memory Modal -->
    <div id="memModal" class="modal">
        <div class="modal-content glass" style="max-width: 400px;">
            <h3>Memoria Personalizada</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">
                Asigna un número de memoria personalizado para tu lista.
            </p>
            <form action="/api/favoritos/update-mem" method="POST">
                <input type="hidden" name="id_dato" id="mem_id_dato">
                <div class="form-group">
                    <label>Nuevo # MEM</label>
                    <input type="text" name="mem_personalizada" id="mem_input" placeholder="Ej: 15">
                </div>
                <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal('memModal')">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add User Modal -->
    <div id="addUserModal" class="modal">
        <div class="modal-content glass">
            <h3>Crear Nuevo Usuario</h3>
            <form action="/api/admin/usuarios" method="POST" class="grid-form">
                <div class="form-group"><label>Nombre Completo</label><input type="text" name="nombre" required></div>
                <div class="form-group"><label>Usuario</label><input type="text" name="usuario" required></div>
                <div class="form-group"><label>Correo</label><input type="email" name="correo" required></div>
                <div class="form-group"><label>Contraseña</label><input type="password" name="password" required></div>
                <div class="form-group full-width">
                    <label>Rol</label>
                    <select name="rol">
                        <option value="usuario">Usuario Regular</option>
                        <option value="admin">Administrador</option>
                    </select>
                </div>
                <div class="full-width" style="display: flex; gap: 1rem; margin-top: 1rem;">
                    <button type="submit" class="btn btn-primary">Crear Usuario</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal('addUserModal')">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit User Modal ... (no changes here but included for context) -->

    <!-- Import CSV Modal -->
    <div id="importModal" class="modal">
        <div class="modal-content glass" style="max-width: 500px;">
            <h3>Importar Frecuencias (CSV)</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
                Sube un archivo .csv (separado por tabulaciones o comas). <br>
                <strong>Encabezados requeridos:</strong> TX, RX, SEÑAL.
            </p>
            <form id="importForm" onsubmit="handleImport(event)" enctype="multipart/form-data">
                <div class="form-group">
                    <label>Archivo CSV</label>
                    <input type="file" name="csv" accept=".csv" required style="padding: 1rem; border: 2px dashed rgba(255,255,255,0.1); width: 100%; border-radius: 0.5rem;">
                </div>
                <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                    <button type="submit" class="btn btn-primary" id="importSubmitBtn">Procesar Archivo</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal('importModal')">Cerrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Import Result Modal -->
    <div id="importResultModal" class="modal">
        <div class="modal-content glass" style="max-width: 600px;">
            <h3>Resultado de la Importación</h3>
            <div id="importSummary" style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 0.5rem; background: rgba(255,255,255,0.05);">
                <!-- Resumen aquí -->
            </div>
            <div id="discardedSection" style="display:none;">
                <h4 style="font-size: 0.9rem; color: var(--danger); margin-bottom: 0.5rem;">Registros Descartados</h4>
                <div style="max-height: 250px; overflow-y: auto; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 0.5rem;">
                    <table style="font-size: 0.8rem;">
                        <thead>
                            <tr><th>Señal</th><th>Motivo</th></tr>
                        </thead>
                        <tbody id="discardedTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div style="margin-top: 1.5rem;">
                <button type="button" class="btn" onclick="window.location.reload()">Aceptar y Recargar</button>
            </div>
        </div>
    </div>

    <script>
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            const content = document.getElementById(`tab-${tabId}`);
            const btn = document.getElementById(`tab-btn-${tabId}`);
            if (content && btn) {
                content.classList.add('active');
                btn.classList.add('active');
                window.location.hash = tabId;
            }
        }

        // Initialize tab from hash
        window.addEventListener('DOMContentLoaded', () => {
            if (window.location.hash) {
                const hash = window.location.hash.substring(1);
                if (['general', 'favoritos', 'revisiones', 'usuarios'].includes(hash)) {
                    showTab(hash);
                }
            }
        });

        async function toggleFavorite(id_dato) {
            try {
                const res = await fetch('/api/favoritos/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id_dato })
                });
                if (res.ok) window.location.reload();
            } catch (err) {
                console.error('Error al cambiar favorito:', err);
            }
        }

        async function clearNotifications() {
            try {
                const res = await fetch('/api/notificaciones/read-all', { method: 'POST' });
                if (res.ok) {
                    const area = document.getElementById('notification-area');
                    if (area) area.style.display = 'none';
                }
            } catch (err) {
                console.error('Error al limpiar notificaciones:', err);
            }
        }

        function openMemModal(id_dato, currentMem) {
            document.getElementById('mem_id_dato').value = id_dato;
            document.getElementById('mem_input').value = currentMem;
            openModal('memModal');
        }

        function editUserRow(u) {
            document.getElementById('editUserForm').action = `/api/admin/usuarios/edit/${u.id}`;
            document.getElementById('edit_user_nombre').value = u.nombre;
            document.getElementById('edit_user_usuario').value = u.usuario;
            document.getElementById('edit_user_correo').value = u.correo;
            document.getElementById('edit_user_rol').value = u.rol;
            openModal('editUserModal');
        }

        function editRow(data) {
            document.getElementById('editForm').action = `/api/datos/edit/${data.id}`;
            document.getElementById('edit_tx').value = data.tx || '';
            document.getElementById('edit_rx').value = data.rx || '';
            document.getElementById('edit_mod').value = data.mod || '';
            document.getElementById('edit_subt').value = data.subt || '';
            document.getElementById('edit_signal').value = data.signal || '';
            document.getElementById('edit_banda').value = data.banda || '';
            document.getElementById('edit_id_estado').value = data.id_estado || '';
            document.getElementById('edit_titular').value = data.titular || '';
            document.getElementById('edit_ciudad').value = data.ciudad || '';
            document.getElementById('edit_id_provincia').value = data.id_provincia || '';
            openModal('editModal');
        }

        function sortTable(tableId, n) {
            const table = document.getElementById(tableId);
            let rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
            switching = true;
            dir = "asc"; 
            while (switching) {
                switching = false;
                rows = table.rows;
                for (i = 0; i < (rows.length - 1); i++) {
                    shouldSwitch = false;
                    x = rows[i].getElementsByTagName("TD")[n];
                    y = rows[i + 1].getElementsByTagName("TD")[n];
                    if (dir == "asc") {
                        if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) {
                            shouldSwitch = true;
                            break;
                        }
                    } else if (dir == "desc") {
                        if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) {
                            shouldSwitch = true;
                            break;
                        }
                    }
                }
                if (shouldSwitch) {
                    rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                    switching = true;
                    switchcount ++;      
                } else {
                    if (switchcount == 0 && dir == "asc") {
                        dir = "desc";
                        switching = true;
                    }
                }
            }
        }

        async function handleImport(event) {
            event.preventDefault();
            const btn = document.getElementById('importSubmitBtn');
            const formData = new FormData(event.target);
            
            btn.disabled = true;
            btn.innerText = 'Procesando...';

            try {
                const res = await fetch('/api/admin/importar-csv', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                
                closeModal('importModal');
                
                const summaryDiv = document.getElementById('importSummary');
                summaryDiv.innerHTML = `
                    <div style="color: var(--success); font-weight: 700; font-size: 1.1rem; margin-bottom: 0.5rem;">🎉 ¡Importación finalizada!</div>
                    <p>✅ <strong>${data.summary.imported}</strong> registros importados con éxito.</p>
                    <p>❌ <strong>${data.summary.discarded}</strong> registros omitidos.</p>
                `;

                if (data.discardedRecords && data.discardedRecords.length > 0) {
                    document.getElementById('discardedSection').style.display = 'block';
                    const tbody = document.getElementById('discardedTableBody');
                    tbody.innerHTML = data.discardedRecords.map(r => `
                        <tr>
                            <td>${r.signal}</td>
                            <td style="color: var(--danger)">${r.reason}</td>
                        </tr>
                    `).join('');
                } else {
                    document.getElementById('discardedSection').style.display = 'none';
                }

                openModal('importResultModal');
            } catch (err) {
                alert('Error al importar el archivo: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.innerText = 'Procesar Archivo';
            }
        }

        window.onclick = function(event) {
            if (event.target.className === 'modal') {
                event.target.style.display = 'none';
            }
        }
    </script>
</body>
</html>
